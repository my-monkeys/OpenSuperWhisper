        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile raggiungere Ollama — è in esecuzione? (ollama serve)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível conectar ao Ollama — ele está em execução? (ollama serve)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Không thể kết nối Ollama — nó có đang chạy không? (ollama serve)"
          }
        }
      }
    },
