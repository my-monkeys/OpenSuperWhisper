    "Press this key during recording to cancel and discard it without transcribing. Defaults to Esc — rebind it here if Esc conflicts with something else.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur cette touche pendant l'enregistrement pour l'annuler et la supprimer sans transcrire. Par défaut Échap — réassignez-la ici si Échap entre en conflit avec autre chose."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Taste während der Aufnahme drücken, um sie abzubrechen und ohne Transkribieren zu verwerfen. Standard ist Esc – hier neu belegen, falls Esc mit etwas anderem kollidiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa esta tecla durante la grabación para cancelarla y descartarla sin transcribir. Por defecto es Esc; reasígnala aquí si Esc entra en conflicto con otra cosa."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi questo tasto durante la registrazione per annullarla e scartarla senza trascriverla. Il valore predefinito è Esc — riassegnalo qui se Esc va in conflitto con qualcos'altro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione esta tecla durante a gravação para cancelá-la e descartá-la sem transcrever. O padrão é Esc — reatribua aqui se Esc conflitar com outra coisa."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nhấn phím này trong khi ghi âm để hủy và bỏ bản ghi mà không phiên âm. Mặc định là Esc — gán lại tại đây nếu Esc xung đột với thứ khác."
          }
        }
      }
    },
    "Press while recording to discard it.": {
      "localizations": {
        "fr": {
          "stringUnit": {
