    "Are you sure you want to delete all recordings? This action cannot be undone.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer tous les enregistrements ? Cette action est irréversible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wirklich alle Aufnahmen löschen? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar todas las grabaciones? Esta acción no se puede deshacer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuoi davvero eliminare tutte le registrazioni? Questa azione non può essere annullata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir todas as gravações? Esta ação não pode ser desfeita."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Bạn có chắc muốn xóa tất cả các bản ghi? Hành động này không thể hoàn tác."
          }
        }
      }
    },
