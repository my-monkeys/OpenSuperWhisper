          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überschreibt die Mac-Sprache nur für OpenSuperWhisper. „System“ folgt der Sprache deines Mac. Dies ist unabhängig von der Transkriptionssprache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anula el idioma de tu Mac solo para OpenSuperWhisper. «Sistema» sigue el idioma de tu Mac. Esto es independiente del idioma de transcripción."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisce la lingua del tuo Mac solo per OpenSuperWhisper. «Sistema» segue la lingua del tuo Mac. È indipendente dalla lingua di trascrizione."
          }
