    "When disabled, audio recordings and transcriptions are not saved to disk. Only the current transcription is kept in memory for pasting.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est désactivée, les enregistrements audio et les transcriptions ne sont pas sauvegardés sur le disque. Seule la transcription en cours est conservée en mémoire pour le collage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deaktiviert, werden Audioaufnahmen und Transkriptionen nicht auf der Festplatte gesichert. Nur die aktuelle Transkription wird zum Einfügen im Speicher gehalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está desactivado, las grabaciones de audio y las transcripciones no se guardan en el disco. Solo se mantiene en memoria la transcripción actual para pegarla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando è disattivato, le registrazioni audio e le trascrizioni non vengono salvate su disco. Solo la trascrizione corrente viene tenuta in memoria per essere incollata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando desativado, as gravações de áudio e as transcrições não são salvas no disco. Apenas a transcrição atual é mantida na memória para colagem."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Khi tắt, bản ghi âm và bản phiên âm sẽ không được lưu vào đĩa. Chỉ bản phiên âm hiện tại được giữ trong bộ nhớ để dán."
          }
        }
      }
    },
