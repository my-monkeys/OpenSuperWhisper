    "Near cursor (default) shows it just above your text caret. Top, Center or Bottom pin it to the middle of the screen instead.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Près du curseur » (par défaut) l'affiche juste au-dessus de votre curseur de texte. « Haut », « Centre » ou « Bas » le fixent plutôt au milieu de l'écran."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Nahe dem Cursor“ (Standard) zeigt sie direkt über der Schreibmarke an. „Oben“, „Mitte“ oder „Unten“ verankern sie stattdessen mittig am Bildschirm."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Cerca del cursor» (predeterminado) lo muestra justo encima del cursor de texto. «Arriba», «Centro» o «Abajo» lo fijan en el centro de la pantalla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Vicino al cursore» (predefinito) lo mostra appena sopra il cursore di testo. «In alto», «Al centro» o «In basso» lo fissano invece al centro dello schermo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Perto do cursor (padrão) mostra logo acima do cursor de texto. Superior, Centro ou Inferior fixam no meio da tela."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gần con trỏ (mặc định) hiển thị ngay phía trên con trỏ văn bản. Trên, Giữa hoặc Dưới sẽ ghim vào giữa màn hình."
          }
        }
      }
    },
